{
  "name": "asciidoc-editor",
  "version": "0.2.0",
  "description": "A portable cross-platform AsciiDoc editor with live preview.",
  "author": "Kim Schulz",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "test": "node --test",
    "package:linux": "npm run build && electron-builder --linux AppImage",
    "package:win": "npm run build && electron-builder --win portable --x64"
  },
  "build": {
    "appId": "org.kimusan.asciidoceditor",
    "productName": "AsciiDoc Editor",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "electronLanguages": [
      "en-US"
    ],
    "icon": "build/icon.png",
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Office"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "vite": "^6.2.1"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/language": "^6.11.2",
    "@codemirror/search": "^6.5.10",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.37.2",
    "@lezer/highlight": "^1.2.1",
    "asciidoctor": "^3.0.4",
    "highlight.js": "^11.11.1"
  }
}
